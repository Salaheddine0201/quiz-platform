              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Nouvel Utilisateur\",\n  \"email\": \"nouveau@quizmaster.com\",\n  \"password\": \"Password1\",\n  \"password_confirmation\": \"Password1\",\n  \"role\": \"enseignant\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/register"
            },
            "description": "Créer un compte. role : `enseignant` ou `etudiant`."
          }
        },
        {
          "name": "Login (Enseignant)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('token', json.token);",
                  "    if (json.user && json.user.id) {",
                  "        pm.collectionVariables.set('user_id', json.user.id);",
                  "    }",
                  "    pm.test('Token enregistré', () => pm.expect(json.token).to.be.a('string'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"prof@quizmaster.com\",\n  \"password\": \"Password1\"\n}",
              "options": {
